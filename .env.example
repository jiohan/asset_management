# ============================================================
# 앱 환경 변수 템플릿 (.env.local 에 실제 값 작성, git 제외)
# ============================================================

# ── Supabase ──────────────────────────────────────────────
# Supabase 대시보드 → Settings → API에서 확인
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ⚠️ 서버 전용 — 절대 클라이언트 코드에 노출 금지
# NEXT_PUBLIC_ 접두사 없이 사용해야 클라이언트에서 접근 불가
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Anthropic Claude API ──────────────────────────────────
# Phase 5 (AI 리포트) 개발 시작 직전에 발급
# https://console.anthropic.com 에서 API 키 생성
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ── Resend (이메일 발송) ──────────────────────────────────
# 공개 베타 오픈 전에 설정 (개발 중에는 Supabase 기본 이메일 사용)
# Supabase SMTP 설정은 .env가 아닌 Supabase 대시보드에서 입력:
# Authentication → Email → SMTP Settings
RESEND_API_KEY=your-resend-api-key-here

# ── Site URL ──────────────────────────────────────────────
# OAuth 리다이렉트, 이메일 링크 기준 URL
# 로컬 개발: http://localhost:3000
# 프로덕션: https://your-domain.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000
